# Backend-managed Gemini API key (optional). Per-user keys entered in the UI
# take priority; this is only used as a fallback for centralized/admin mode.
# Get a key at https://ai.google.dev/
GOOGLE_API_KEY=

# JWT signing secret — set this to a long random string in production
JWT_SECRET_KEY=change-me-to-a-long-random-string

# CORS origins allowed to call the API (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Stripe — get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Get this after running `stripe listen --forward-to localhost:8000/billing/webhook`
STRIPE_WEBHOOK_SECRET=
# Pro plan price in cents (e.g. 499 = $4.99/month)
STRIPE_PRO_PRICE_AMOUNT=499
FRONTEND_URL=http://localhost:5173

# Postgres (optional) — leave unset to use local SQLite instead
DATABASE_URL=

# Resend — get a key at https://resend.com/api-keys
# Without a verified domain, the resend.dev sandbox sender can only deliver to
# the email address on your own Resend account (fine for testing).
RESEND_API_KEY=
RESEND_FROM_EMAIL=Documind AI <onboarding@resend.dev>

# development | production — production refuses to start with an insecure JWT_SECRET_KEY
ENVIRONMENT=development
